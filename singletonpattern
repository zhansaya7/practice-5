import java.io.*;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;

public class SingletonLoggerDemo {

    enum LogLevel {
        INFO,
        WARNING,
        ERROR
    }

    static class Logger {

        private static volatile Logger instance;
        private LogLevel currentLevel = LogLevel.INFO;
        private String logFilePath = "app.log";
        private final Object lock = new Object();

        private Logger() { }

        public static Logger getInstance() {
            if (instance == null) {
                synchronized (Logger.class) {
                    if (instance == null) {
                        instance = new Logger();
                    }
                }
            }
            return instance;
        }

        public void setLogLevel(LogLevel level) {
            this.currentLevel = level;
        }

        public void log(String message, LogLevel level) {
            if (level.ordinal() < currentLevel.ordinal()) return;

            synchronized (lock) {
                try (FileWriter fw = new FileWriter(logFilePath, true);
                     BufferedWriter bw = new BufferedWriter(fw)) {

                    String time = LocalDateTime.now()
                            .format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss"));

                    bw.write(time + " [" + level + "] " + message);
                    bw.newLine();

                } catch (IOException e) {
                    e.printStackTrace();
                }
            }
        }
    }

    static class LogReader {
        public static void readLogs(String path, LogLevel levelFilter) {
            try (BufferedReader br = new BufferedReader(new FileReader(path))) {
                String line;
                while ((line = br.readLine()) != null) {
                    if (line.contains(levelFilter.toString())) {
                        System.out.println(line);
                    }
                }
            } catch (Exception e) {
                e.printStackTrace();
            }
        }
    }

    public static void main(String[] args) {

        Logger logger = Logger.getInstance();
        logger.setLogLevel(LogLevel.INFO);

        Runnable task = () -> {
            logger.log("Information message", LogLevel.INFO);
            logger.log("Warning message", LogLevel.WARNING);
            logger.log("Error message", LogLevel.ERROR);
        };

        for (int i = 0; i < 5; i++) {
            new Thread(task).start();
        }

        try { Thread.sleep(1000); } catch (Exception e) {}

        System.out.println("=== ERROR LOGS ===");
        LogReader.readLogs("app.log", LogLevel.ERROR);
    }
}
